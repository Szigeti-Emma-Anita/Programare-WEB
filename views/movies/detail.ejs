<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalii Film - <%= movie.titlu %></title>
    <style>
        body { 
            font-family: 'Segoe UI', Arial, sans-serif; 
            background-color: #000000; 
            color: #ffffff; 
            margin: 0; 
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center; 
        }
        
        .card { 
            background: #141414; 
            padding: 40px; 
            border-radius: 10px; 
            border: 1px solid #333;
            display: inline-block; 
            min-width: 350px; 
        }
        
        h1 { color: #e50914; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 1px; }
        
        hr { border: 0; border-top: 1px solid #333; margin: 20px 0; }
        
        p { font-size: 1.1em; color: #b3b3b3; margin: 12px 0; }
        
        b { color: #ffffff; }

        .links-container { margin-top: 30px; }

        .back-link { 
            display: inline-block; 
            color: #ffffff; 
            text-decoration: none; 
            font-weight: bold; 
            padding: 8px 15px;
            border: 1px solid #444;
            border-radius: 4px;
            background-color: #222;
        }
        
        .logout-link { 
            display: inline-block;
            color: #e50914; 
            margin-left: 15px; 
            text-decoration: none; 
            font-weight: bold;
        }

        .back-link:hover, .logout-link:hover {
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="card">
        <h1><%= movie.titlu %></h1>
        <hr>
        <p><b>Regizor:</b> <%= movie.regizor %></p>
        <p><b>An apariție:</b> <%= movie.an %></p>
        <p><b>Gen:</b> <%= movie.gen %></p>
        <p><b>Rating:</b> <%= movie.rating %>/10</p>
        <p><b>Status:</b> <%= movie.vizionat ? "Vizionat" : "De vizionat" %></p>
        
        <div class="links-container">
            <a href="/movies" class="back-link">⬅ Înapoi la catalog</a>
            <a href="/logout" class="logout-link">Logout</a>
        </div>
    </div>

</body>
</html>